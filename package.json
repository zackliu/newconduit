{
  "name": "agent-runtime-sidecar-poc",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript POC framework for Agent Runtime Sidecar central service and sidecar daemon.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node -e \"require('fs').rmSync('dist-tests', { recursive: true, force: true })\" && tsc -p tsconfig.test.json && node --test --test-force-exit \"dist-tests/tests/**/*.test.js\" \"dist-tests/sdk/client/tests/**/*.test.js\"",
    "build:sdk": "pnpm --dir sdk/client build",
    "typecheck:sdk": "pnpm --dir sdk/client typecheck",
    "test:sdk": "pnpm --dir sdk/client test",
    "start:central": "node dist/central/main.js",
    "start:sidecar": "node dist/sidecar/main.js",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\""
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "dependencies": {
    "@azure/identity": "^4.13.1",
    "@azure/web-pubsub": "^1.2.0",
    "@azure/web-pubsub-client": "^1.0.4",
    "@github/copilot-sdk": "1.0.3"
  }
}