{
  "agentSpecId": "dotnet-poc",
  "labels": {
    "agent": "dotnet",
    "tier": "poc"
  },
  "launch": {
    "command": "copilot",
    "args": []
  },
  "toolProfile": "copilot-poc-tools",
  "workerSelector": {
    "matchLabels": {
      "agent": "dotnet",
      "storage": "volume-snapshot"
    }
  },
  "pausePolicy": "turn-boundary-durable-pause",
  "recoveryPolicy": "restart-with-context",
  "idlePauseTimeoutMs": 300000,
  "version": "poc-v1"
}
